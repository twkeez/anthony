# Copy to `.env.local` (same folder). Never commit real secrets.
# Full matrix: docs/ENVIRONMENT.md

NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_public_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_secret_key

NEXT_PUBLIC_APP_URL=http://localhost:3000

GOOGLE_CLIENT_ID=your_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_client_secret

# PageSpeed Insights v5 (Lighthouse category scores on metrics sync). Create an API key in Google Cloud Console
# (API: PageSpeed Insights) and restrict by HTTP referrer to your app URL in production.
# https://developers.google.com/speed/docs/insights/v5/get-started
GOOGLE_PAGESPEED_API_KEY=your_pagespeed_api_key

# Google Ads API (required for Ads metrics sync) — exact value from Ads: Tools → API Center (no spaces).
# Test-access tokens only work with test accounts; production accounts need Basic/Standard access on the token.
GOOGLE_ADS_DEVELOPER_TOKEN=your_developer_token
# Optional: MCC / manager account ID (10 digits, dashes optional). Sent as login-customer-id only when set.
# If omitted or commented out, that header is not sent (direct customer access).
# GOOGLE_ADS_LOGIN_CUSTOMER_ID=9959915312

# Google Gemini for “Generate AI analysis” on the client detail page
GOOGLE_GEMINI_API_KEY=your_gemini_api_key
# Optional; default is gemini-2.5-flash (v1 API). gemini-2.5-pro has much lower free-tier RPM; use Flash for dev or enable billing.
# GEMINI_MODEL=gemini-2.5-pro

# Basecamp 2 API — /dashboard/dev/basecamp-mapper
# Account id in the browser URL (https://basecamp.com/XXXXXXX/...). Used for projects.json AND per-project
# todo_lists / topics (communication sync). Wrong id → HTTP 404 on every project fetch.
# BASECAMP_ACCOUNT_ID defaults to 2175055 if unset — set explicitly if your account is different.
# BASECAMP_ACCOUNT_ID=2175055

# Option A — HTTP Basic (private integration). User id is usually your sign-in email; if you get 401, set
# BASECAMP_BASIC_USER to the exact username Basecamp shows on “Me” → “My profile” (not always the email).
BASECAMP_USER_EMAIL=you@example.com
BASECAMP_PASSWORD=your_password
# BASECAMP_BASIC_USER=Firstname Lastname

# Option B — OAuth access token (Bearer). When set, BASECAMP_PASSWORD is ignored for API calls.
# BASECAMP_ACCESS_TOKEN=...

# In production, enable the dev mapper route explicitly:
# ENABLE_BASECAMP_MAPPER=1
# Or only the read-only people directory (id + email + name) at /dashboard/dev/basecamp-people:
# ENABLE_BASECAMP_DIRECTORY=1

# Communication sync — who counts as “agency” on Basecamp message boards (vs client / external).
# Prefer the Staff table (Dashboard → Team): active rows match by email, Basecamp person id, display name, or full name.
# 1) When last_updater.email_address is present: match staff email, else Beyond domains (@beyond, *.beyond, beyond.com).
# 2) Legacy fallback if there are zero active staff rows: comma-separated names / person ids:
# AGENCY_TEAM_NAMES=Alex Smith,Jamie Lee
# AGENCY_TEAM_IDS=149087659
# If email is missing AND staff + env lists cannot classify, last post source is “unknown”.

# Staff sync (Dashboard → Team → Sync from Basecamp): comma-separated full Gmail/Googlemail
# addresses allowed in addition to @beyondindigo.com (e.g. Beth, Courtney, Hollis).
# STAFF_SYNC_GMAIL_WHITELIST=beth@example.com,courtney@example.com,hollis@example.com

# --- Dashboard session (optional; when BOTH are set, workspace + API routes require login) ---
# DASHBOARD_PASSWORD=choose-a-strong-shared-password
# DASHBOARD_SESSION_SECRET=min-16-chars-random-secret-for-cookie-signature

# POST /api/sync from Vercel Cron without browser session (optional)
# SYNC_CRON_SECRET=random-secret-for-bearer-token

# Log Gemini prompt fingerprints (optional): 1 = on
# GEMINI_DEBUG_LOGS=1
